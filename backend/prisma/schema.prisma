generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

//
// ENUMS
//

enum UserRole {
  admin
  worker
}

enum PaymentMethod {
  CASH
  MPESA
  BANK_TRANSFER
  CREDIT
}

enum OrderStatus {
  COMPLETED
  REFUNDED
  CANCELLED
}

//
// USERS
//

model User {
  id             String   @id @default(uuid())

  fullName       String
  username       String?  @unique
  email          String   @unique
  phone          String?

  passwordHash   String

  role           UserRole

  isActive       Boolean  @default(true)

  orders         Order[]
  restocks       Restock[]
  auditLogs      AuditLog[]
  refreshTokens  RefreshToken[]

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("users")
}

//
// REFRESH TOKENS
//

model RefreshToken {
  id          String   @id @default(uuid())

  token       String   @unique

  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  expiresAt   DateTime

  createdAt   DateTime @default(now())

  @@map("refresh_tokens")
}

//
// CATEGORIES
//

model Category {
  id           String    @id @default(uuid())

  name         String    @unique
  description  String?
  color        String?

  products     Product[]

  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@map("categories")
}

//
// SUPPLIERS
//

model Supplier {
  id              String    @id @default(uuid())

  supplierName    String
  contactPerson   String?

  phone           String?
  email           String?
  address         String?

  products        Product[]
  restocks        Restock[]

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@map("suppliers")
}

//
// PRODUCTS
//

model Product {
  id              String    @id @default(uuid())

  productCode     String    @unique

  name            String
  description     String?

  buyingPrice     Decimal   @db.Decimal(12, 2)
  sellingPrice    Decimal   @db.Decimal(12, 2)

  quantity        Int       @default(0)

  reorderLevel    Int       @default(10)

  categoryId      String?
  category        Category? @relation(fields: [categoryId], references: [id])

  supplierId      String?
  supplier        Supplier? @relation(fields: [supplierId], references: [id])

  orderItems      OrderItem[]
  restocks        Restock[]

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([name])
  @@index([productCode])
  @@map("products")
}

//
// CUSTOMERS
//

model Customer {
  id           String    @id @default(uuid())

  name         String
  email        String?   @unique
  phone        String?

  address      String?

  orders       Order[]

  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@map("customers")
}

//
// ORDERS
//

model Order {
  id              String         @id @default(uuid())

  orderNumber     String         @unique
  receiptNumber   String         @unique

  customerId      String?
  customerName    String?
  customer        Customer?      @relation(fields: [customerId], references: [id])

  subtotal        Decimal        @db.Decimal(12, 2)
  discount        Decimal        @default(0) @db.Decimal(12, 2)
  taxAmount       Decimal        @default(0) @db.Decimal(12, 2)
  totalAmount     Decimal        @db.Decimal(12, 2)

  paymentMethod   PaymentMethod

  status          OrderStatus    @default(COMPLETED)

  createdById     String
  createdBy       User           @relation(fields: [createdById], references: [id])

  items           OrderItem[]

  createdAt       DateTime       @default(now())

  @@index([orderNumber])
  @@index([receiptNumber])
  @@index([createdAt])
  @@map("orders")
}

//
// ORDER ITEMS
//

model OrderItem {
  id             String    @id @default(uuid())

  orderId        String
  order          Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)

  productId      String
  product        Product   @relation(fields: [productId], references: [id])

  quantity       Int

  unitPrice      Decimal   @db.Decimal(12, 2)

  total          Decimal   @db.Decimal(12, 2)

  @@map("order_items")
}

//
// RESTOCKS
//

model Restock {
  id              String    @id @default(uuid())

  productId       String
  product         Product   @relation(fields: [productId], references: [id])

  quantityAdded   Int

  supplierId      String
  supplier        Supplier  @relation(fields: [supplierId], references: [id])

  cost            Decimal   @db.Decimal(12, 2)

  notes           String?

  receivedById    String
  receivedBy      User      @relation(fields: [receivedById], references: [id])

  createdAt       DateTime  @default(now())

  @@index([createdAt])
  @@map("restocks")
}

//
// AUDIT LOGS
//

model AuditLog {
  id           String    @id @default(uuid())

  userId       String?
  user         User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  action       String

  details      String?

  createdAt    DateTime  @default(now())

  @@index([createdAt])
  @@map("audit_logs")
}

//
// NOTIFICATIONS
//

model Notification {
  id           String    @id @default(uuid())

  title        String

  message      String

  isRead       Boolean   @default(false)

  createdAt    DateTime  @default(now())

  @@map("notifications")
}

//
// SETTINGS
//

model Setting {
  id                String    @id @default(uuid())

  businessName      String

  logoUrl           String?

  address           String?

  phone             String?

  email             String?

  taxRate           Decimal?  @db.Decimal(5, 2)

  currency          String?   @default("KES")

  receiptFooter     String?

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@map("settings")
}

//
// FUTURE MULTI-BRANCH SUPPORT
//

model Branch {
  id           String    @id @default(uuid())

  name         String
  address      String?
  phone        String?

  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@map("branches")
}
