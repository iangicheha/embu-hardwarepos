{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "rootDir": "src",
    "outDir": "dist",

    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,

    "forceConsistentCasingInFileNames": true,

    "moduleResolution": "node16",

    "resolveJsonModule": true,

    "types": ["node", "jest"]
  },

  "include": ["src/**/*", "src/types/**/*"],

  "exclude": [
    "node_modules",
    "dist"
  ]
}